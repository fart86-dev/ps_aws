{
  "name": "ps-aws-infra-monitor",
  "version": "1.0.0",
  "description": "AWS Infrastructure monitoring for RDS, DynamoDB, and WAF",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:bg": "bash scripts/dev-bg.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:bg": "bash scripts/start-bg.sh",
    "stop": "bash scripts/stop.sh",
    "type-check": "tsc --noEmit",
    "logs": "tail -f app.log"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.614.0",
    "@aws-sdk/client-dynamodb": "^3.614.0",
    "@aws-sdk/client-rds": "^3.614.0",
    "@aws-sdk/client-wafv2": "^3.614.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
